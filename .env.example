# 真实 Pi 集成测试专用变量（仅 `pnpm test:real:pi` 通过 --env-file=.env 读取）。
# 复制为 .env 并填入真实值；切勿提交真实凭证。应用启动 / 普通测试 / 构建 / 打包均不读取。

# DEV_API_KEY: 开发供应商 API Key（必填；不得输出/持久化/传给 Renderer）。
DEV_API_KEY=
# DEV_API_URL: 开发供应商 Base URL（必填；日志只显示脱敏后的 origin）。
DEV_API_URL=
# DEV_API_DEFAULT_MODEL: 真实测试使用的模型（必填；仅覆盖测试 route，不改变产品内置模型表）。
DEV_API_DEFAULT_MODEL=
# DEV_API_TYPE: 开发供应商协议类型（必填；取值须映射到受支持的 ProviderKind）。
# 可选值：anthropic | openai | google | deepseek | openrouter | openai_compatible | anthropic_compatible
DEV_API_TYPE=openai_compatible
