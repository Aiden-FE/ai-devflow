{
  "name": "ai-devflow",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "test": "pnpm --recursive --if-present run test && pnpm test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:real:pi": "pnpm --filter @ai-devflow/desktop stage:pi && node --env-file=.env scripts/run-real-pi-test.mjs",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "lint": "pnpm --recursive --if-present run lint",
    "dev": "pnpm --filter @ai-devflow/desktop dev",
    "verify": "pnpm -r typecheck && pnpm -r lint && pnpm -r test && pnpm test:scripts",
    "verify:unit": "pnpm -r --if-present run test && pnpm test:scripts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
